{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!cache", "!dist", "!build", "!src/data", "!**/*.d.ts"]
  },
  "formatter": {
    "enabled": true,
    "useEditorconfig": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.{js,mjs,cjs,jsx,mjsx,ts,tsx,mtsx}"],
      "linter": {
        "rules": {
          "a11y": "info",
          "correctness": {
            "noUndeclaredVariables": "error",
            "useExhaustiveDependencies": "info",
            "useParseIntRadix": "info"
          },
          "style": {
            "noNonNullAssertion": "off",
            "useAsConstAssertion": "error"
          },
          "suspicious": {
            "noArrayIndexKey": "info",
            "noConstantBinaryExpressions": "error",
            "noDuplicateEnumValues": "error",
            "noEmptyBlockStatements": "error",
            "noUnknownAttribute": "error",
            "noUnusedExpressions": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "info"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "recommended": true
    }
  }
}
