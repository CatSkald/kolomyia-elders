{
  "name": "kolomyia-elder-map",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --watch",
    "lint": "biome check --error-on-warnings --diagnostic-level=warn",
    "preview": "vite preview",
    "deploy": "tsc && vite build && npx gh-pages -d dist",
    "upgrade": "npx npm-check-updates --upgrade && npm install"
  },
  "dependencies": {
    "@maptiler/leaflet-maptilersdk": "^4.1.1",
    "leaflet": "^1.9.4",
    "leaflet-hash": "^0.2.1",
    "leaflet-providers": "^3.0.0",
    "react": "^19.2.7",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-string-replace": "^2.0.1",
    "reactjs-popup": "^2.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
